generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
enum BackgroundCheckStatus{
  pending
  approved
  rejected
}

enum Availability{
  offline
  online
  busy
}

model caregiverprofile {
  id                      Int       @id @default(autoincrement())
  user_id                 Int
  bio                     String?
  availability_status     Availability @default(offline) 
  hourly_rate             Decimal?  @db.Decimal(10, 2)
  verified                Boolean?  @default(false)
  background_check_status BackgroundCheckStatus    @default(pending)
  created_at              DateTime? @default(now()) @db.Timestamp(6)
  updated_at              DateTime? @default(now()) @db.Timestamp(6)
  users                   users     @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
enum MobilityLevel {
  independent
  needs_assistant
  wheelchair
}

model elderprofile {
  id              Int               @id @default(autoincrement())
  first_name      String            @db.VarChar(100)
  last_name       String            @db.VarChar(100)
  date_of_birth   DateTime?         @db.Date
  address         String?
  phone           String?           @db.VarChar(30)
  medical_notes   String?
  mobility_level  MobilityLevel     @default(independent)
  notes           String?
  created_at      DateTime?         @default(now()) @db.Timestamp(6)
  familyelderlink familyelderlink[]
}

enum TokenType{
  EMAIL_VERIFICATION
  PASSWORD_RESET
}
model authtokens {
  id                 Int       @id @default(autoincrement())
  user_id            Int
  verification_title String?   @db.VarChar(200)
  code               String    @db.VarChar(255)
  expires_at         DateTime  @db.Timestamp(6)
  used               Boolean?  @default(false)
  type               TokenType @default(EMAIL_VERIFICATION)
  created_at         DateTime? @default(now()) @db.Timestamp(6)
  users              users     @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
}

model familyelderlink {
  id                  Int                 @id @default(autoincrement())
  family_member_id    Int
  elder_id            Int
  relationship        String?             @db.VarChar(50)
  is_primary_contact  Boolean?            @default(false)
  created_at          DateTime?           @default(now()) @db.Timestamp(6)
  elderprofile        elderprofile        @relation(fields: [elder_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  familymemberprofile familymemberprofile @relation(fields: [family_member_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([family_member_id, elder_id])
}

model familymemberprofile {
  id                    Int               @id @default(autoincrement())
  user_id               Int               @unique
  relationship_to_elder String?           @db.VarChar(50)
  created_at            DateTime?         @default(now()) @db.Timestamp(6)
  familyelderlink       familyelderlink[]
  users                 users             @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
}

model servicecategories {
  category_id   Int            @id @default(autoincrement())
  category_name String         @unique @db.VarChar(100)
  description   String?
  is_active     Boolean?       @default(true)
  created_at    DateTime?      @default(now()) @db.Timestamp(6)
  servicetasks  servicetasks[]
}

model servicetasks {
  service_id        Int               @id @default(autoincrement())
  category_id       Int
  service_name      String            @db.VarChar(100)
  description       String?
  is_active         Boolean?          @default(true)
  created_at        DateTime?         @default(now()) @db.Timestamp(6)
  updated_at        DateTime?         @default(now()) @db.Timestamp(6)
  servicecategories servicecategories @relation(fields: [category_id], references: [category_id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([category_id, service_name])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
enum UserRole{
  elder
  family
  caregiver
  admin
}

enum Gender{
  male
  female
  other
  pnts
}

model users {
  user_id               Int                     @id @default(autoincrement())
  role                  UserRole                @default(family)
  first_name            String?                 @db.VarChar(100)
  last_name             String?                 @db.VarChar(100)
  email                 String                  @unique @db.VarChar(255)
  phone_number          String?                 @unique @db.VarChar(30)
  password_hash         String?
  date_of_birth         DateTime?               @db.Date
  gender                Gender?                 
  address               String?
  city                  String?                 @db.VarChar(100)
  country               String?                 @default("Finland") @db.VarChar(100)
  is_verified           Boolean?                @default(false)
  created_at            DateTime?               @default(now()) @db.Timestamp(6)
  updated_at            DateTime?               @default(now()) @db.Timestamp(6)
  email_verified        Boolean?                @default(false)
  caregiverprofile      caregiverprofile[]
  emailverificationcode authtokens[]
  familymemberprofile   familymemberprofile?
}