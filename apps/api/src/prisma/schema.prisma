// prisma/schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

// -----------------------------------------------------------------------------
// ENUMS
// -----------------------------------------------------------------------------

enum Gender {
  MALE
  FEMALE
  OTHER
  UNSPECIFIED
}

enum ROLE {
  SUPER_ADMIN
  AGENCY_STAFF
  SUPERVISOR
  CAREGIVER
}

enum VisitStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}


enum TaskFrequency {
  DAILY
  ON_DEMAND
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum CaregiverRole {
  CAREGIVER
  HEAD_NURSE
  COORDINATOR
}

enum CaregiverStatus {
  ACTIVE
  IN_ACTIVE
  SUSPENDED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
}

// -----------------------------------------------------------------------------
// ORGANIZATION
// -----------------------------------------------------------------------------

model CareHomeAgency {
  id            Int            @id @default(autoincrement())
  name          String
  address       String?
  users         User[]
  residents     Resident[]
  taskTemplates TaskTemplate[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("care_home_agencies")
}

// -----------------------------------------------------------------------------
// USER (AUTH + IDENTITY)
// -----------------------------------------------------------------------------

model User {
  userId       String  @id @map("user_id") @default(cuid())
  email        String  @unique
  passwordHash String  @map("password_hash")
  firstName    String  @map("first_name")
  lastName     String  @map("last_name")
  roles        ROLE[]
  active       Boolean @default(true)

  agencyId Int?            @map("agency_id")
  agency   CareHomeAgency? @relation(fields: [agencyId], references: [id])

  caregiverProfile Caregiver? 
  staffProfile     StaffProfile?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([agencyId])
  @@map("users")
}

// -----------------------------------------------------------------------------
// ROLE-SPECIFIC PROFILES
// -----------------------------------------------------------------------------

model Caregiver {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relation to User
  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [userId])

  phone          String?
  role           CaregiverRole
  status         CaregiverStatus @default(ACTIVE)
  employmentType EmploymentType  @map("employment_type")
  hireDate       DateTime        @map("hire_date")

  certifications Certification[]
  visits         Visit[]
  actionRecords  ActionRecord[]

  @@map("caregivers")
}

model Certification {
  id          String    @id @default(cuid())
  name        String
  issuer      String
  validFrom   DateTime  @map("valid_from")
  validTo     DateTime? @map("valid_to")
  caregiverId String    @map("caregiver_id")
  caregiver   Caregiver @relation(fields: [caregiverId], references: [id], onDelete: Cascade)

  @@map("certifications")
}

model StaffProfile {
  id     String @id @default(cuid())
  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [userId])

  department     String?
  title          String?
  canAssignTasks Boolean @default(false) @map("can_assign_tasks")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("staff_profiles")
}

// -----------------------------------------------------------------------------
// RESIDENTS
// -----------------------------------------------------------------------------

enum MobilityLevel {
  INDEPENDENT
  ASSISTED
  MEMORY
}

enum AllergySeverity {
  MILD
  MODERATE
  SEVERE
}

model Resident {
  residentId String   @id @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  mrn       String   @unique
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  birthDate DateTime @map("birth_date")
  gender    Gender

  email String?
  phone String?

  mobilityLevel MobilityLevel
  room          String?

  primaryCaregiverId String? // reference to CaregiverManagement (string only)
  guardianUserId     String? // reference to IdentityAccess.User (string only)

  allergies               Allergy[]
  medications             Medication[]
  emergencyContacts       EmergencyContact[]
  careHomeAgency          CareHomeAgency?          @relation(fields: [careHomeAgencyId], references: [id])
  careHomeAgencyId        Int? @map("care_home_agency_id")
  visits                  Visit[]
  residentTaskAssignments ResidentTaskAssignment[]

  @@map("residents")
}

model Allergy {
  id         String          @id @default(cuid())
  name       String
  reaction   String
  severity   AllergySeverity
  notes      String?
  resident   Resident        @relation(fields: [residentId], references: [residentId], onDelete: Cascade)
  residentId String

  @@map("allergies")
}

model Medication {
  id           String    @id @default(cuid())
  name         String
  dosage       String
  frequency    String
  startDate    DateTime  @map("start_date")
  endDate      DateTime? @map("end_date")
  prescribedBy String? @map("prescribed_by")
  resident     Resident  @relation(fields: [residentId], references: [residentId], onDelete: Cascade)
  residentId   String

  @@map("medications")
}

model EmergencyContact {
  id         String   @id @default(cuid())
  name       String
  relation   String
  phone      String
  email      String?
  preferred  Boolean  @default(false)
  resident   Resident @relation(fields: [residentId], references: [residentId], onDelete: Cascade)
  residentId String

  @@map("emergency_contacts")
}

// -----------------------------------------------------------------------------
// VISITS
// -----------------------------------------------------------------------------

model Visit {
  visitId String @id @map("visit_id")

  caregiverId String    @map("caregiver_id")
  caregiver   Caregiver @relation(fields: [caregiverId], references: [id])

  residentId String   @map("resident_id")
  resident   Resident @relation(fields: [residentId], references: [residentId])

  scheduledStart DateTime  @map("scheduled_start")
  scheduledEnd   DateTime  @map("scheduled_end")
  actualStart    DateTime? @map("actual_start")
  actualEnd      DateTime? @map("actual_end")

  status VisitStatus @default(PLANNED)

  taskInstances TaskInstance[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("visits")
}

// -----------------------------------------------------------------------------
// TASK TEMPLATES
// -----------------------------------------------------------------------------

model TaskTemplate {
  id          Int           @id @default(autoincrement())
  name        String
  description String?
  category    String
  frequency   TaskFrequency

  requiresInput Boolean   @default(false) @map("requires_input")
  inputSchema   Json?     @map("input_schema")
  riskLevel     RiskLevel @default(LOW) @map("risk_level")

  agencyId Int            @map("agency_id")
  agency   CareHomeAgency @relation(fields: [agencyId], references: [id])

  assignments   ResidentTaskAssignment[]
  taskInstances TaskInstance[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("task_templates")
}

// -----------------------------------------------------------------------------
// RESIDENT TASK ASSIGNMENT
// -----------------------------------------------------------------------------

model ResidentTaskAssignment {
  id Int @id @default(autoincrement())

  residentId String   @map("resident_id")
  resident   Resident @relation(fields: [residentId], references: [residentId])

  taskTemplateId Int          @map("task_template_id")
  taskTemplate   TaskTemplate @relation(fields: [taskTemplateId], references: [id])

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("resident_task_assignments")
}

// -----------------------------------------------------------------------------
// TASK INSTANCE (EXECUTION)
// -----------------------------------------------------------------------------

model TaskInstance {
  id String @id @default(cuid())

  visitId String @map("visit_id")
  visit   Visit  @relation(fields: [visitId], references: [visitId])

  taskTemplateId Int          @map("task_template_id")
  taskTemplate   TaskTemplate @relation(fields: [taskTemplateId], references: [id])

  status TaskStatus @default(PENDING)

  actions ActionRecord[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([visitId])
  @@index([taskTemplateId])
  @@map("task_instances")
}

// -----------------------------------------------------------------------------
// ACTION RECORDS (AUDIT LOG)
// -----------------------------------------------------------------------------

model ActionRecord {
  id Int @id @default(autoincrement())

  taskInstanceId String       @map("task_instance_id")
  taskInstance   TaskInstance @relation(fields: [taskInstanceId], references: [id])

  caregiverId String    @map("caregiver_id")
  caregiver   Caregiver @relation(fields: [caregiverId], references: [id])

  value Json?
  notes String?

  createdAt DateTime @default(now()) @map("created_at")

  @@map("action_records")
}



enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskCategory {
  CARE
  MEDICATION
  HYGIENE
  ADMIN
  OTHER
}

model Task {
  id                     String        @id @default(cuid())
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  title                  String
  description            String?

  category               TaskCategory
  priority               TaskPriority
  status                 TaskStatus    @default(PENDING)

  residentId             String?       // reference to Resident BC (string only)
  assignedCaregiverId    String?       // reference to Caregiver BC (string only)

  dueAt                  DateTime?
  startedAt              DateTime?
  completedAt            DateTime?
  completedByCaregiverId String?
  completionNotes        String?

  createdByUserId        String

  checklist              ChecklistItem[]
}

model ChecklistItem {
  id                 String   @id @default(cuid())
  label              String
  required           Boolean  @default(false)
  done               Boolean  @default(false)
  doneAt             DateTime?
  doneByCaregiverId  String?

  task               Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId             String
}
