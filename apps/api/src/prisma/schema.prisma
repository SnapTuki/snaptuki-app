// prisma/schema.prisma

// -----------------------------------------------------------------------------
// Datasource & Generator
// -----------------------------------------------------------------------------

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

// -----------------------------------------------------------------------------
// ENUMS
// -----------------------------------------------------------------------------

enum ROLE {
  SUPER_ADMIN
  AGENCY_STAFF
  SUPERVISOR
  CAREGIVER
}

enum VisitStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskStatus {
  PENDING
  COMPLETED
  SKIPPED
}

enum TaskFrequency {
  DAILY
  ON_DEMAND
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

// -----------------------------------------------------------------------------
// ORGANIZATION
// -----------------------------------------------------------------------------

model CareHomeAgency {
  id          Int      @id @default(autoincrement())
  name        String
  address     String?

  users       User[]
  residents   Resident[]
  taskTemplates TaskTemplate[]

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("care_home_agencies")
}

// -----------------------------------------------------------------------------
// USER (AUTH + IDENTITY)
// -----------------------------------------------------------------------------


model User {
  userId       String  @id  @map("user_id")

  email        String  @unique
  passwordHash String  @map("password_hash")

  firstName    String  @map("first_name")
  lastName     String  @map("last_name")

  roles        ROLE[]
  active       Boolean @default(true)

  // FIX: agencyId should match CareHomeAgency.id (Int).
  agencyId     Int?    @map("agency_id")
  // FIX: if FK optional, make relation optional.
  agency       CareHomeAgency? @relation(fields: [agencyId], references: [id])

  caregiverProfile CaregiverProfile?
  staffProfile     StaffProfile?

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([agencyId])
  @@map("users")
}

// -----------------------------------------------------------------------------
// ROLE-SPECIFIC PROFILES
// -----------------------------------------------------------------------------

model CaregiverProfile {
  id              String      @id

  userId          String      @unique @map("user_id")
  user            User     @relation(fields: [userId], references: [userId])

  jobTitle        String   @map("job_title")
  employmentType  String   @map("employment_type")
  licenseNumber   String?  @map("license_number")

  visits          Visit[]
  actions         ActionRecord[]

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("caregiver_profiles")
}

model StaffProfile {
  id              String      @id

  userId          String      @unique @map("user_id")
  user            User     @relation(fields: [userId], references: [userId])

  department      String?
  title           String?
  canAssignTasks  Boolean  @default(false) @map("can_assign_tasks")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("staff_profiles")
}

// -----------------------------------------------------------------------------
// RESIDENTS
// -----------------------------------------------------------------------------

model Resident {
  residentId            String      @id @unique @map("resident_id")
  firstName     String   @map("first_name")
  lastName     String   @map("last_name")
  roomNumber    String   @map("room_number")

  agencyId      Int      @map("agency_id")
  agency        CareHomeAgency @relation(fields: [agencyId], references: [id])

  visits        Visit[]
  taskAssignments ResidentTaskAssignment[]

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("residents")
}

// -----------------------------------------------------------------------------
// VISITS
// -----------------------------------------------------------------------------

model Visit {
  visitId              String      @id @map("visit_id")

  caregiverId     String      @map("caregiver_id")
  caregiver       CaregiverProfile @relation(fields: [caregiverId], references: [id])

  residentId      String      @map("resident_id")
  resident        Resident @relation(fields: [residentId], references: [residentId])

  scheduledStart  DateTime @map("scheduled_start")
  scheduledEnd    DateTime @map("scheduled_end")
  actualStart     DateTime? @map("actual_start")
  actualEnd       DateTime? @map("actual_end")

  status          VisitStatus @default(PLANNED)

  taskInstances   TaskInstance[]

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("visits")
}

// -----------------------------------------------------------------------------
// TASK TEMPLATES
// -----------------------------------------------------------------------------

model TaskTemplate {
  id            Int      @id @default(autoincrement())

  name          String
  description   String?
  category      String
  frequency     TaskFrequency

  requiresInput Boolean  @default(false) @map("requires_input")
  inputSchema   Json?    @map("input_schema")
  riskLevel     RiskLevel @default(LOW) @map("risk_level")

  agencyId      Int      @map("agency_id")
  agency        CareHomeAgency @relation(fields: [agencyId], references: [id])

  assignments   ResidentTaskAssignment[]
  taskInstances TaskInstance[]

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("task_templates")
}

// -----------------------------------------------------------------------------
// RESIDENT TASK ASSIGNMENT
// -----------------------------------------------------------------------------

model ResidentTaskAssignment {
  id              Int      @id @default(autoincrement())

  residentId      String      @map("resident_id")
  resident        Resident @relation(fields: [residentId], references: [residentId])

  taskTemplateId  Int      @map("task_template_id")
  taskTemplate    TaskTemplate @relation(fields: [taskTemplateId], references: [id])

  isActive        Boolean  @default(true) @map("is_active")

  createdAt       DateTime @default(now()) @map("created_at")

  @@map("resident_task_assignments")
}

// -----------------------------------------------------------------------------
// TASK INSTANCE (EXECUTION)
// -----------------------------------------------------------------------------

model TaskInstance {
  id              String   @id

  // FIX: Visit.visitId is String, so this must be String too
  visitId         String   @map("visit_id")
  visit           Visit    @relation(fields: [visitId], references: [visitId])

  taskTemplateId  Int      @map("task_template_id")
  taskTemplate    TaskTemplate @relation(fields: [taskTemplateId], references: [id])

  status          TaskStatus @default(PENDING)

  actions         ActionRecord[]

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([visitId])
  @@index([taskTemplateId])
  @@map("task_instances")
}

// -----------------------------------------------------------------------------
// ACTION RECORDS (AUDIT LOG)
// -----------------------------------------------------------------------------

model ActionRecord {
  id              Int      @id @default(autoincrement())

  taskInstanceId  String      @map("task_instance_id")
  taskInstance    TaskInstance @relation(fields: [taskInstanceId], references: [id])

  caregiverId     String      @map("caregiver_id")
  caregiver       CaregiverProfile @relation(fields: [caregiverId], references: [id])

  value           Json?
  notes           String?

  createdAt       DateTime @default(now()) @map("created_at")

  @@map("action_records")
}
