generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CaregiverProfile {
  id            Int       @id @default(autoincrement())
  first_name    String?   @db.VarChar(100)
  last_name     String?   @db.VarChar(100)
  phone_number  String?   @unique @db.VarChar(30)
  date_of_birth DateTime? @db.Date
  gender        Gender?
  address       String?
  city          String?   @db.VarChar(100)
  country       String?   @default("Finland") @db.VarChar(100)

  bio                     String?
  availability_status     Availability          @default(offline)
  hourly_rate             Decimal?              @db.Decimal(10, 2)
  verified                Boolean?              @default(false)
  background_check_status BackgroundCheckStatus @default(pending)
  created_at              DateTime?             @default(now()) @db.Timestamp(6)
  updated_at              DateTime?             @default(now()) @db.Timestamp(6)
  user                    User                  @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
  user_id                 Int                   @unique(map: "caregiver_user_id")
  bookings                Booking[]
  care_task_books         CareTaskBook[]

  @@map("caregiver_profiles")
}

model ElderProfile {
  id             Int               @id @default(autoincrement())
  first_name     String            @db.VarChar(100)
  last_name      String            @db.VarChar(100)
  date_of_birth  DateTime?         @db.Date
  address        String?           @db.VarChar(100)
  postal_code    String?           @db.VarChar(10)
  city           String?           @db.VarChar(100)
  country        String?
  phone          String?           @db.VarChar(30)
  medical_notes  String?
  mobility_level MobilityLevel     @default(independent)
  created_at     DateTime?         @default(now()) @db.Timestamp(6)
  family_members FamilyWithElder[]
  bookings       Booking[]
  careTaskBooks  CareTaskBook[]

  @@map("elder_profiles")
}

model AuthTokens {
  id         Int       @id @default(autoincrement())
  user_id    Int
  title      String?   @map("verification_title") @db.VarChar(200)
  code       String    @db.VarChar(255)
  expires_at DateTime  @db.Timestamp(6)
  used       Boolean?  @default(false)
  type       TokenType @default(EMAIL_VERIFICATION)
  created_at DateTime? @default(now()) @db.Timestamp(6)

  @@map("authtokens")
}

model FamilyWithElder {
  id               Int                 @id @default(autoincrement())
  family           FamilymemberProfile @relation(fields: [family_member_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  family_member_id Int
  elderprofile     ElderProfile        @relation(fields: [elder_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  elder_id         Int
  relationship     String?             @db.VarChar(50)
  created_at       DateTime?           @default(now()) @db.Timestamp(6)

  @@map("family_with_elders")
}

model FamilymemberProfile {
  id            Int       @id @default(autoincrement())
  first_name    String?   @db.VarChar(100)
  last_name     String?   @db.VarChar(100)
  phone_number  String?   @unique @db.VarChar(30)
  date_of_birth DateTime? @db.Date
  gender        Gender?
  address       String?
  postal_code   String?   @db.VarChar(10)
  city          String?   @db.VarChar(100)
  country       String?   @default("Finland") @db.VarChar(100)

  managed_elders FamilyWithElder[]
  user           User              @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
  user_id        Int               @unique
  bookings       Booking[]

  @@map("familymemberprofile")
}

model ServiceCategory {
  category_id   Int           @id @default(autoincrement())
  category_name String        @unique @db.VarChar(100)
  description   String?
  is_active     Boolean?      @default(true)
  created_at    DateTime?     @default(now()) @db.Timestamp(6)
  servicetasks  ServiceTask[]

  @@map("servicecategories")
}

model ServiceTask {
  id                Int             @id @default(autoincrement())
  category_id       Int
  service_name      String          @db.VarChar(100)
  description       String?
  is_active         Boolean?        @default(true)
  created_at        DateTime?       @default(now()) @db.Timestamp(6)
  updated_at        DateTime?       @default(now()) @db.Timestamp(6)
  servicecategories ServiceCategory @relation(fields: [category_id], references: [category_id], onDelete: Cascade, onUpdate: NoAction)
  bookings          Booking[]

  @@unique([category_id, service_name])
  @@map("servicetasks")
}

model User {
  user_id Int      @id @default(autoincrement())
  role    UserRole

  email         String  @unique @db.VarChar(255)
  password_hash String?

  is_verified         Boolean?             @default(false)
  created_at          DateTime?            @default(now()) @db.Timestamp(6)
  updated_at          DateTime?            @default(now()) @db.Timestamp(6)
  caregiverprofile    CaregiverProfile?
  familymemberprofile FamilymemberProfile?

  @@map("users")
}

model Booking {
  id Int @id @default(autoincrement())

  //relations
  family_member    FamilymemberProfile @relation(fields: [family_member_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  family_member_id Int

  caregiver    CaregiverProfile @relation(fields: [caregiver_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  caregiver_id Int

  elder    ElderProfile @relation(fields: [elder_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  elder_id Int

  care_service    ServiceTask @relation(fields: [care_service_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  care_service_id Int

  //bookings details
  status BookingStatus @default(PENDING)

  start_time DateTime @db.Timestamp(6)
  end_time   DateTime @db.Timestamp(6)

  notes String?

  total_price Int

  //taskbook
  care_task_book CareTaskBook?

  // Audit fields
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)

  @@map("bookings")
}

model CareTaskBook {
  id Int @id @default(autoincrement())

  booking_id   Int @unique
  caregiver_id Int
  elder_id     Int

  status CareTaskBookStatus @default(ACTIVE)

  started_at   DateTime? @db.Timestamp(6)
  completed_at DateTime? @db.Timestamp(6)

  notes String?

  // relations
  booking   Booking          @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  caregiver CaregiverProfile @relation(fields: [caregiver_id], references: [id], onDelete: Cascade)
  elder     ElderProfile     @relation(fields: [elder_id], references: [id], onDelete: Cascade)

  tasks CareTask[]

  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @updatedAt @db.Timestamp(6)

  @@map("caretaskbooks")
}

model CareTask {
  id Int @id @default(autoincrement())

  task_book_id Int
  title        String  @db.VarChar(200)
  description  String?

  task_order   Int
  is_mandatory Boolean @default(true)

  status CareTaskStatus @default(PENDING)

  completed_at    DateTime? @db.Timestamp(6)
  caregiver_notes String?

  // relations
  taskbook CareTaskBook @relation(fields: [task_book_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @updatedAt @db.Timestamp(6)

  @@index([task_book_id])
  @@map("caretasks")
}

// ENUMS

enum CareTaskBookStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum CareTaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  SKIPPED
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
enum BackgroundCheckStatus {
  pending
  approved
  rejected
}

enum Availability {
  offline
  online
  busy
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
enum MobilityLevel {
  independent
  needs_assistant
  wheelchair
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
enum UserRole {
  ELDER
  FAMILY
  CAREGIVER
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PNTS
}

enum BookingStatus {
  DRAFT
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  EXPIRED
}
